---
import Photo from './Photo.astro';

interface Image {
  src: string | null;
  alt: string;
  title: string;
  description?: string;
  href?: string;
}

interface Props {
  images: Image[];
  label: string;
}

const { images, label } = Astro.props;
const total = String(images.length).padStart(2, '0');
const hasMultiple = images.length > 1;
---

<section
  class="carousel"
  data-carousel
  aria-roledescription="carousel"
  aria-label={`${label} — photographs`}
>
  <div class="carousel__frame">
    {
      hasMultiple && (
        <button type="button" class="arrow arrow--prev" data-prev aria-label="Previous photograph">
          ←
        </button>
      )
    }

    <div class="carousel__stage">
      {
        images.map((image, i) => (
          <figure class="slide" data-slide hidden={i !== 0}>
            <div class="slide__image">
              <Photo
                src={image.src}
                alt={image.alt}
                fit="contain"
                loading={i === 0 ? 'eager' : 'lazy'}
                placeholderLabel={`Photograph ${String(i + 1).padStart(2, '0')}`}
              />
            </div>
            <figcaption class="slide__caption">
              <span class="slide__title">
                {image.href ? (
                  <a href={image.href} rel="noopener" target="_blank">
                    {image.title} ↗
                  </a>
                ) : (
                  image.title
                )}
              </span>
              {image.description && <span class="slide__description">{image.description}</span>}
            </figcaption>
          </figure>
        ))
      }
    </div>

    {
      hasMultiple && (
        <button type="button" class="arrow arrow--next" data-next aria-label="Next photograph">
          →
        </button>
      )
    }
  </div>

  {
    hasMultiple && (
      <p class="counter label" aria-live="polite">
        <span data-current>01</span> / {total}
      </p>
    )
  }
</section>

<style>
  .carousel {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* Prev/next sit either side of the photo on desktop, so the image itself can
     run bigger than the homepage's 560px featured photo. `grid-column: 2` is
     set explicitly on the stage so it still lands in the centre track when a
     single-image series renders no arrows at all. */
  .carousel__frame {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 28px;
    width: 100%;
    max-width: 880px;
  }

  .carousel__stage {
    grid-column: 2;
    width: 100%;
  }

  .arrow {
    grid-row: 1;
    font-family: var(--font-mono);
    font-size: 22px;
    line-height: 1;
    color: inherit;
    background: none;
    border: 0;
    padding: 10px;
    cursor: pointer;
  }

  .arrow--prev {
    grid-column: 1;
  }

  .arrow--next {
    grid-column: 3;
  }

  .arrow:hover,
  .arrow:focus-visible {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .counter {
    text-align: center;
    margin: 18px 0 0;
    color: var(--muted);
  }

  .slide {
    margin: 0;
  }

  .slide[hidden] {
    display: none;
  }

  /* A fixed stage keeps the controls still while portrait and landscape frames
     take turns — the photographs letterbox against white instead. */
  .slide__image {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slide__image :global(.photo) {
    max-height: 100%;
    width: auto;
    max-width: 100%;
  }

  .slide__image :global(.placeholder) {
    height: 100%;
  }

  .slide__caption {
    text-align: center;
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.7;
    letter-spacing: 0.5px;
    color: var(--caption);
  }

  .slide__title {
    display: block;
  }

  .slide__description {
    display: block;
    color: var(--muted);
  }

  @media (max-width: 480px) {
    .slide__caption {
      margin-top: 14px;
      font-size: 10px;
    }

    /* Not enough width beside a full-bleed mobile photo for side arrows — drop
       them below the image instead, side by side either end of the row, the
       same spot they held before this layout split at 480px. */
    .carousel__frame {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    /* `order` (not DOM position) decides placement: the stage claims the
       first line on its own via flex-basis 100%, then both arrows share the
       line below it, which `space-between` spreads to either edge. */
    .carousel__stage {
      order: 1;
      flex: 1 1 100%;
    }

    .arrow--prev {
      order: 2;
    }

    .arrow--next {
      order: 3;
    }

    .arrow {
      font-size: 14px;
      padding: 6px 0;
    }

    .counter {
      margin-top: 12px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
    const slides = [...carousel.querySelectorAll<HTMLElement>('[data-slide]')];
    const current = carousel.querySelector<HTMLElement>('[data-current]');
    const prev = carousel.querySelector<HTMLButtonElement>('[data-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-next]');
    if (slides.length < 2) return;

    let index = 0;

    const show = (to: number) => {
      // Wrap in both directions so the ends are never dead.
      index = (to + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        slide.hidden = i !== index;
      });
      if (current) current.textContent = String(index + 1).padStart(2, '0');
    };

    prev?.addEventListener('click', () => show(index - 1));
    next?.addEventListener('click', () => show(index + 1));

    document.addEventListener('keydown', (event) => {
      if (event.metaKey || event.ctrlKey || event.altKey) return;
      if (event.key === 'ArrowLeft') show(index - 1);
      if (event.key === 'ArrowRight') show(index + 1);
    });
  });
</script>
