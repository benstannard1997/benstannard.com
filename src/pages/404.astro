---
import Frame from '../layouts/Frame.astro';
---

<Frame title="Not found — Ben Stannard" description="This page does not exist." indexLabel="ERROR 404">
  <div class="notfound">
    <p class="label">NO SUCH PAGE</p>
    <p class="label label--muted"><a href="/">← RETURN TO INDEX</a></p>
  </div>
</Frame>

<style>
  .notfound {
    margin: auto;
    text-align: center;
  }

  .notfound p {
    margin: 0 0 12px;
  }
</style>
