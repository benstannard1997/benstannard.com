---
import Frame from '../layouts/Frame.astro';
import Photo from '../components/Photo.astro';
import { featured } from '../data/site';

const { photo, caption, index } = featured;
---

<Frame
  title="Ben Stannard — Photography, Sheffield UK"
  indexLabel={`INDEX ${index}`}
  indexHref="/series"
  midLeft={{ label: 'UNTITLED (PROFILE)', href: '/about' }}
  midRight={{ label: 'WORK ↗', href: '/series' }}
>
  <figure class="featured">
    <a class="featured__link" href="/series" aria-label={`${photo.title} — view work`}>
      <Photo src={photo.src} alt={photo.alt} loading="eager" />
    </a>
    <figcaption class="caption">
      <div>{caption.author}</div>
      <div class="caption__location">{caption.location}</div>
      <div class="caption__location caption__location--short">{caption.locationShort}</div>
      <div>{caption.place}</div>
    </figcaption>
  </figure>
</Frame>

<style>
  /* Absolutely centred on the page, per the handoff — not centred in the space
     left between header and footer, which would sit a couple of px low. */
  .featured {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 560px;
    max-width: 100%;
    margin: 0;
  }

  /* Reserve the photo's height so a short viewport grows the frame instead of
     letting the header and footer collide with the photograph. */
  :global(.main:has(.featured)) {
    min-height: 520px;
  }

  .featured__link:hover {
    text-decoration: none;
  }

  .caption {
    text-align: center;
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.7;
    letter-spacing: 0.5px;
    color: var(--caption);
  }

  .caption__location--short {
    display: none;
  }

  @media (max-width: 480px) {
    /* Mobile drops absolute centring for a single column: the photo area is
       flexible and centres itself between the header and the footer. */
    .featured {
      position: static;
      transform: none;
      width: 100%;
      margin: auto 0;
    }

    :global(.main:has(.featured)) {
      min-height: 0;
    }

    .caption {
      margin-top: 14px;
      font-size: 10px;
    }

    .caption__location {
      display: none;
    }

    .caption__location--short {
      display: block;
    }
  }
</style>
