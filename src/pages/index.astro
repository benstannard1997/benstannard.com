---
import { getCollection } from 'astro:content';
import Frame from '../layouts/Frame.astro';
import HomeCarousel from '../components/HomeCarousel.astro';

// The design holds four hero photos at most. Every frontmatter field on this
// collection is optional (see content.config.ts), so a raw entry might be
// missing anything below — fall back to something sane for each, including
// the position-dependent ones (index, order) a single file's schema can't
// default on its own.
const raw = (await getCollection('home'))
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 4);

const photos = raw.map((entry, i) => {
  const { data } = entry;
  const location = data.caption?.location || data.caption?.locationShort || 'Untitled';
  return {
    index: data.index || String(i + 1).padStart(3, '0'),
    image: {
      src: data.image?.src ?? null,
      alt: data.image?.alt || 'Featured photograph',
    },
    caption: {
      author: data.caption?.author || 'Ben Stannard',
      location,
      locationShort: data.caption?.locationShort || location,
      place: data.caption?.place || data.year || '',
    },
  };
});

// Server-rendered fallback for when JS is off — the client script picks a
// random one of these on load and takes over from there.
const first = photos[0];
---

<Frame
  title="Ben Stannard — Photography, Sheffield UK"
  indexLabel={`INDEX ${first.index}`}
  indexHref="/series"
>
  <div class="featured">
    <HomeCarousel photos={photos} />
  </div>
</Frame>

<style>
  /* Absolutely centred on the page, per the handoff — not centred in the space
     left between header and footer, which would sit a couple of px low. */
  .featured {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 100%;
    margin: 0;
  }

  /* Reserve the photo's height so a short viewport grows the frame instead of
     letting the header and footer collide with the photograph. Sized for a
     square 610px photo (610 + ~90px of caption) now that images render at
     their own aspect ratio instead of being cropped into a 4:3 box. */
  :global(.main:has(.featured)) {
    min-height: 710px;
  }

  @media (max-width: 480px) {
    /* Mobile drops absolute centring for a single column: the photo area is
       flexible and centres itself between the header and the footer. */
    .featured {
      position: static;
      transform: none;
      width: 100%;
      margin: auto 0;
    }

    :global(.main:has(.featured)) {
      min-height: 0;
    }
  }
</style>
