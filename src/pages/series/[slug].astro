---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Frame from '../../layouts/Frame.astro';
import Carousel from '../../components/Carousel.astro';

export const getStaticPaths = (async () => {
  const series = await getCollection('series');
  return series.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, index, year, location, summary, images } = entry.data;

// Every field on an image entry is optional (see content.config.ts) — fall
// back to something sane for `alt`/`title` so a photo dropped in without
// captioning it yet still builds and still has real accessible text.
const normalizedImages = images.map((image, i) => ({
  src: image.src ?? null,
  alt: image.alt || `${title} — photograph ${i + 1}`,
  title: image.title || `Photograph ${String(i + 1).padStart(2, '0')}`,
  description: image.description,
  href: image.href,
}));
---

<Frame
  title={`${title} — Ben Stannard`}
  description={summary}
  indexLabel={`SERIES ${index}`}
  indexHref="/series"
  yearLabel={`${year} →`}
>
  <header class="head">
    <h1 class="head__title">{title}</h1>
    <p class="head__meta label label--muted">
      {location ? `${location} — ${year}` : year}
    </p>
  </header>

  <Carousel images={normalizedImages} label={title} />

  <div class="prose">
    <Content />
  </div>
</Frame>

<style>
  .head {
    margin: 56px 0 24px;
    text-align: center;
  }

  .head__title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0;
  }

  .head__meta {
    margin: 8px 0 0;
  }

  /* Wider than the site-wide .prose default so the body copy runs under the
     carousel at roughly the same width as the enlarged photo above it. */
  .prose {
    max-width: 760px;
    margin: 48px auto 56px;
  }

  @media (max-width: 480px) {
    .head {
      margin: 32px 0 20px;
    }

    .head__title {
      font-size: 13px;
    }

    .prose {
      margin: 32px auto;
    }
  }
</style>
