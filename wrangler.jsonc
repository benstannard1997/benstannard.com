{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "benstannardcom",
  "compatibility_date": "2026-07-17",
  // Static-assets-only Worker: no `main` entrypoint, Cloudflare serves ./dist directly.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
